# =============================================================================
# Whitelist-based .gitignore for lorrax_sandbox
#
# Strategy: ignore everything, then selectively un-ignore the file types and
# directories we want tracked. This prevents accidentally committing large
# HDF5 files, binary wavefunctions, compiled objects, or GPU libraries.
# =============================================================================

# Ignore everything by default
*

# --- Un-ignore directory structure (recursively) ---
!*/

# --- Un-ignore documentation and config ---
!*.md
!*.yaml
!*.yml
!*.toml
!*.txt
!*.json

# --- Un-ignore source code and scripts ---
!*.py
!*.sh

# --- Un-ignore input files ---
!*.in
!*.inp

# --- Un-ignore small data files ---
!*.dat
!*.csv
!*.spec

# --- Un-ignore pseudopotentials ---
!*.upf
!*.UPF

# --- Un-ignore plots (keep PNGs for reports) ---
!*.png

# --- Un-ignore git housekeeping ---
!.gitignore
!.gitkeep
!.python-version

# =============================================================================
# Re-ignore things that match above patterns but should NOT be tracked
# =============================================================================

# Virtual environment (contains .py, .so, etc.)
.venv/

# Python caches
__pycache__/
*.pyc
*.pyo

# uv lock file (large, auto-generated)
uv.lock

# Jupyter
.ipynb_checkpoints/

# Editor/IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# =============================================================================
# Explicitly blocked large/binary types (defense in depth)
# =============================================================================
*.h5
*.hdf5
*.nc
*.npy
*.npz
*.pkl
*.pickle
*.so
*.o
*.a
*.dylib

# BGW binary formats (no extension)
# These are caught by the whitelist approach, but for clarity:
# WFN, WFNq, EpsDyn, EpsInvDyn are all binary and extensionless,
# so they're already ignored by the default * rule.
