# GWJAX input for MoS2 GN-PPM debugging
# nband must match number_bands in epsilon.inp and sigma.inp
[cohsex]

restart = true

centroids_file = centroids_frac_600.txt

nval = 26
ncond = 44
nband = 80
sys_dim = 2

x_only = false
do_screened = true
bispinor = false
# How QP energies are extracted from Sigma (orthogonal to the Sigma ansatz):
#   one_shot_dft    - standard G0W0, everything evaluated at E_DFT (default)
#   fixed_point     - one-shot Sigma + diagonal on-shell solve E = h0 + ReSigma(E)
#                     (dynamic modes only; governs the eigh-family outputs)
#   self_consistent - full QSGW loop (see sc_* keys in COHSEX_INPUT.md)
qp_solver = one_shot_dft

use_ppm_sigma = true
screening_method = minimax
ppm_omega_p = 2.0
ppm_fallback_omega = 2.0
# Invalid (Omega^2<0) PPM poles: static_limit (default, BGW invalid_gpp_mode 3:
# static-COHSEX term) | zero (drop, BGW 0) | 2ry (keep fallback pole, BGW 2)
ppm_invalid_mode = static_limit
sigma_omega_min_ev = -10.0
sigma_omega_max_ev = 10.0
sigma_omega_step_ev = 0.5
sigma_regularization_ev = 0.25
ppm_sigma_scale = 1.0
ppm_sigma_flip_neg = false
sigma_debug_split_contrib = true
fermi_reference = midgap
sigma_at_dft_extrapolate = false
ppm_sigma_debug_static_norm = false
sigma_debug_quadrature = false

# chunked algorithm for memory-intensive step; 0.0 uses full device mem
use_chunked_isdf = true
memory_per_device_gb = 0.0

# for debugging
write_no_head_vw = true
debug_hartree = true
write_w_copies_debug = true

wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
sigma_freq_debug_output = true # writes sigma_freq_debug.dat, helpful

K_POINTS {crystal_b}
4
  0.0000 0.0000 0.0000 80
  0.0000 0.5000 0.0000 80
  0.3333 0.3333 0.0000 80
  0.0000 0.0000 0.0000 80
