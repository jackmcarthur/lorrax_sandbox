&control
   prefix = 'co'
   calculation = 'scf'
   restart_mode = 'from_scratch'
   pseudo_dir = './'
/
&system
   ibrav = 0
   celldm(1) = 13.228
   nat = 2
   ntyp = 2
   nbnd = 12
   ecutwfc = 25.0
   noncolin = .true.
   lspinorb = .true.
   no_t_rev = .true.
/
&electrons
   electron_maxstep = 100
   conv_thr = 1.0d-10
   mixing_mode = 'plain'
   mixing_beta = 0.7
   mixing_ndim = 8
   diagonalization = 'david'
   diago_david_ndim = 4
   diago_full_acc = .true.
/
CELL_PARAMETERS alat
       1.000000000   0.000000000   0.000000000
       0.000000000   1.000000000   0.000000000
       0.000000000   0.000000000   1.000000000
ATOMIC_SPECIES
   C  12.011  C.upf
   O  15.999  O.upf
ATOMIC_POSITIONS bohr
   C  -1.066000000   0.000000000   0.000000000
   O   1.066000000   0.000000000   0.000000000
K_POINTS crystal
1
0.0 0.0 0.0 1.0