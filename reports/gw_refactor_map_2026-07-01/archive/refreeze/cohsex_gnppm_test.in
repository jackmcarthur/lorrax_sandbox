[cohsex]
restart = false
x_only = false
do_screened = true
compute_mode = gn_ppm
use_ppm_sigma = true
# --- GN-PPM dynamic Sigma_c config (was missing; caused build_G shape crash) ---
ppm_omega_p = 2.0
ppm_fallback_omega = 2.0
sigma_omega_min_ev = -10.0
sigma_omega_max_ev = 10.0
sigma_omega_step_ev = 0.5
sigma_regularization_ev = 0.25
sigma_at_dft_energies = true
fermi_reference = midgap
sigma_omega_h5_file = sigma_mnk_gnppm.h5
bispinor = false
wfn_file = WFNsmall.h5
centroids_file = centroids_frac_60.txt
output_file = eqp_gnppm_test.dat
sigma_diag_file = eqp_gnppm_test.dat
eqp0_file = eqp0_gnppm_test.dat
eqp1_file = eqp1_gnppm_test.dat
nval = 4
ncond = 4
nband = 40
sys_dim = 2
screening_method = minimax
use_ffi_io = false
no_degen_averaging = true

