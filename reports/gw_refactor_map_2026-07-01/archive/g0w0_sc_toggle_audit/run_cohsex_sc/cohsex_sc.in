[cohsex]
# SC-COHSEX compile-count audit (G0W0_SC_TOGGLE_DESIGN) — MoS2 3x3 WFNsmall,
# 60 centroids, self_consistent=true, linear mixing, 3 iterations forced.
compute_mode = cohsex
restart = false
x_only = false
do_screened = true
bispinor = false
self_consistent = true
wfn_file = WFNsmall.h5
centroids_file = centroids_frac_60.txt
kin_ion_file = kin_ion.h5
sigma_diag_file = sigma_diag_sc.dat
eqp0_file = eqp0_sc.dat
eqp1_file = eqp1_sc.dat
nval = 4
ncond = 4
nband = 40
sys_dim = 2
screening_method = minimax
use_ffi_io = false
no_degen_averaging = true
write_wfn_h5 = false
