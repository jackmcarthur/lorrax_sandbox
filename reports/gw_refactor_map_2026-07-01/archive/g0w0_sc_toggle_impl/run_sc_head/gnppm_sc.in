[cohsex]
# SC-GN-PPM compile-count audit — MoS2 3x3 full WFN, 642 centroids,
# self_consistent=true, linear mixing, 3 iterations forced.
compute_mode = gn_ppm
restart = false
centroids_file = centroids_frac_642.txt
kin_ion_file = kin_ion.h5
nval = 26
ncond = 54
nband = 80
sys_dim = 2
x_only = false
do_screened = true
bispinor = false
self_consistent = true
use_ppm_sigma = true
screening_method = minimax
ppm_omega_p = 2.0
ppm_fallback_omega = 2.0
sigma_omega_min_ev = -10.0
sigma_omega_max_ev = 10.0
sigma_omega_step_ev = 0.5
sigma_regularization_ev = 0.25
memory_per_device_gb = 28
fermi_reference = midgap
wfn_file = WFN.h5
sigma_diag_file = sigma_diag_gnppm_sc.dat
sigma_omega_h5_file = sigma_mnk.h5
write_wfn_h5 = false
