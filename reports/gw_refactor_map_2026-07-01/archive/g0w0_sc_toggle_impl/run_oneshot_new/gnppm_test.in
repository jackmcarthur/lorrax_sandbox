[cohsex]
# GN-PPM regression gate seed on a fresh full WFN (MoS2 3x3, nspinor=2)
compute_mode = gn_ppm
restart = false
centroids_file = centroids_frac_642.txt
nval = 26
ncond = 54
nband = 80
sys_dim = 2
x_only = false
do_screened = true
bispinor = false
qp_solver = one_shot_dft
use_ppm_sigma = true
screening_method = minimax
ppm_omega_p = 2.0
ppm_fallback_omega = 2.0
sigma_omega_min_ev = -10.0
sigma_omega_max_ev = 10.0
sigma_omega_step_ev = 0.5
sigma_regularization_ev = 0.25
use_chunked_isdf = true
memory_per_device_gb = 28
sigma_freq_debug_output = true
sigma_debug_split_contrib = true
fermi_reference = midgap
wfn_file = WFN.h5
output_file = sigma_diag_gnppm_test.dat
sigma_diag_file = sigma_diag_gnppm_test.dat
sigma_omega_h5_file = sigma_mnk.h5
