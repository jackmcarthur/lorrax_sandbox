# BGW epsilon for Si 2x2x2 COHSEX - nosym (8 k-points, no symmetry)
epsilon_cutoff 60.0
degeneracy_check_override
use_wfn_hdf5
frequency_dependence 3
broadening 0.001
number_bands 60

write_vcoul

begin qpoints
  0.000100000  0.000000000  0.000000000   1.0 1
  0.000000000  0.000000000  0.500000000   1.0 0
  0.000000000  0.500000000  0.000000000   1.0 0
  0.000000000  0.500000000  0.500000000   1.0 0
  0.500000000  0.000000000  0.000000000   1.0 0
  0.500000000  0.000000000  0.500000000   1.0 0
  0.500000000  0.500000000  0.000000000   1.0 0
  0.500000000  0.500000000  0.500000000   1.0 0
end
