# Si 2x2x2 60Ry COHSEX with BGW 100sl pseudobands (216 bands)
# 1600 ISDF centroids — first point of centroid convergence sweep
[cohsex]
restart = false
centroids_file = centroids_frac_1600.txt

nval = 8
ncond = 208
nband = 216
sys_dim = 3
bispinor = false
self_consistent = false

x_only = false
do_screened = true
use_ppm_sigma = false
screening_method = minimax

bare_coulomb_cutoff = 60.0

# BGW head + body overlay (Si canonical recipe)
vhead = 825.937
whead_0freq = 17.128
use_bgw_vcoul = true
bgw_vcoul_file = bgw_vcoul.dat

use_chunked_isdf = true
memory_per_device_gb = 28
sigma_at_dft_energies = true
sigma_freq_debug_output = true
sigma_debug_split_contrib = true
fermi_reference = midgap

wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
minimax_target_error = 1.0e-6
bgw_vcoul_sym_wfn = ../qe/nscf/WFN.h5
