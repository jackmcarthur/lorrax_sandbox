&control
   prefix = 'Bi'
   pseudo_dir = './'
   calculation = 'nscf'
/
&system
   ecutwfc = 40.0
   ibrav = 5
   celldm(1) = 9.0
   celldm(4) = 0.5417
   nat = 2
   ntyp = 1
   noncolin = .true.
   lspinorb = .true.
   nbnd = 34
   occupations = 'smearing'
   smearing = 'fd'
   degauss = 0.005
/
&electrons
   electron_maxstep = 100
   conv_thr = 1e-9
   mixing_mode = 'plain'
   mixing_beta = 0.5
   diagonalization = 'david'
/

ATOMIC_SPECIES
   Bi 208.98 'Bi.upf'

ATOMIC_POSITIONS crystal
   Bi  0.234  0.234  0.234
   Bi -0.234 -0.234 -0.234

