&control
   prefix = 'CrI3'
   pseudo_dir = './'
   calculation = 'nscf'
   verbosity = 'high'
   wf_collect = .true.
   disk_io = 'low'
/
&system
   ecutwfc = 30.0
   ibrav = 0
   nat = 8
   ntyp = 2
   noncolin = .true.
   lspinorb = .true.
   no_t_rev = .true.
   nbnd = 82
   assume_isolated = '2D'
/
&electrons
   electron_maxstep = 200
   conv_thr = 1e-9
   diagonalization = 'david'
   diago_david_ndim = 4
   diago_full_acc = .true.
/

