&control
   prefix = 'CrI3'
   pseudo_dir = './'
   calculation = 'nscf'
   verbosity = 'high'
   wf_collect = .true.
   disk_io = 'low'
/
&system
   ecutwfc = 30.0
   ibrav = 0
   nat = 8
   ntyp = 2
   noncolin = .true.
   lspinorb = .true.
   no_t_rev = .true.
   noinv = .true.
   nbnd = 120
   assume_isolated = '2D'
   nosym = .true.
   starting_magnetization(1) = 0.5
   starting_magnetization(2) = 0.0
   angle1(1) = 0.0
   angle1(2) = 0.0
   angle2(1) = 0.0
   angle2(2) = 0.0
/
! Band-path NSCF ('bands') reusing the FM SCF density from ../scf.
! starting_magnetization REQUIRED: without it QE sets domag=.false. and
! ignores the magnetization part of the SCF density -> non-magnetic bands.
! nosym=.true. keeps the explicit k-path points untouched and avoids the
! irrek_nc crash that magnetic-symmetry analysis hits on an explicit k-list.
&electrons
   electron_maxstep = 200
   conv_thr = 1e-9
   diagonalization = 'david'
   diago_david_ndim = 4
   diago_full_acc = .true.
/

