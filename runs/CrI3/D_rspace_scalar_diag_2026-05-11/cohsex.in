[cohsex]
wfn_file = WFN.h5
nval = 70
ncond = 80
nband = 150
sys_dim = 2
bispinor = false

centroids_file = centroids_frac_1500.txt

# Single user-facing memory knob.  After the Z_q reshard fix
# (isdf_fitting.py: two-step via P(None,None,'y') stage), the chunker's
# native prediction is honest at this budget.  Bc-loop unrolling cost
# is still implicit (Python loop in the jit body) but stays within
# headroom on this system.
memory_per_device_gb = 70.0

restart = false

# DIAGNOSTIC: bpd=10 (= total band_chunk 160) so the bc-loop in
# fit_one_rchunk's @jax.jit kernel runs ONCE (n_bc = ceil(160/160) = 1)
# instead of being Python-unrolled n_bc times.  fit_one_rchunk has a
# Python ``for bc in band_chunk_ranges`` inside the jit (isdf_fitting.py
# line ~976) that creates n_bc copies of the FFT + pair-density body in
# the HLO IR — likely the source of the absurd host-side compile RAM.
# Falsification: if n_bc=1 doesn't host-OOM, the Python unroll is the
# bug.  The proper fix is jax.lax.scan instead of the Python loop.
band_chunk_size = 4
r_chunk_size = 70000
max_r_chunks = -1

# Bare-X (Σ_X = -GV, no screening): exercises the bispinor zeta + V_q
# pipeline end-to-end without needing dipole.h5 / eps0mat.h5.  The σ
# stage forwards V_blocks[(0,0)] and produces a charge-channel-only Σ.
x_only = true
do_screened = false
screening = cohsex

# Bypass head_resolver eps0mat / dipole requirement for x_only.
vhead = 0.0
whead_0freq = 0.0
