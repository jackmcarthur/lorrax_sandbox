[cohsex]
wfn_file = WFN.h5
nval = 8
ncond = 8
nband = 80
sys_dim = 2
bispinor = true

centroids_file = centroids_frac_1800.txt
centroids_file_current = centroids_frac_1808_current.txt

bare_coulomb_cutoff = 50.0
epsilon_cutoff = 50.0
restart = false

# Single user-facing memory knob.  No r_chunk_size / band_chunk_size /
# max_r_chunks overrides — the chunker auto-sizes from this budget.
memory_per_device_gb = 30.0

screening = cohsex
