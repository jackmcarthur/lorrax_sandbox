# LORRAX GN-PPM with noavg overlay (matches BGW 03_bgw_gnppm_noavg)
[cohsex]
restart = false
centroids_file = centroids_frac_1440.txt

nval = 8
ncond = 52
nband = 60
sys_dim = 3
bare_coulomb_cutoff = 25.0

x_only = false
do_screened = true
bispinor = false
self_consistent = false

use_ppm_sigma = true
screening_method = minimax

# PPM frequency grid
ppm_omega_p = 2.0
ppm_fallback_omega = 2.0
sigma_omega_min_ev = -15.0
sigma_omega_max_ev = 15.0
sigma_omega_step_ev = 0.5
sigma_regularization_ev = 0.25

# BGW v overlay — same as canonical recipe
vhead = 3303.748102
whead_0freq = 150.338765
use_bgw_vcoul = true
bgw_vcoul_file = bgw_vcoul.dat

use_chunked_isdf = true
memory_per_device_gb = 28
sigma_at_dft_energies = true
sigma_freq_debug_output = true
sigma_debug_split_contrib = true
fermi_reference = midgap

wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
minimax_target_error = 1.0e-6
