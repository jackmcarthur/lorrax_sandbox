[cohsex]
# Si 4x4x4 nosym, pseudobands (8 prot + 98 pseudo), GN-PPM, scissor on.
nval = 8
ncond = 98
nband = 106
sys_dim = 3
bispinor = false

wfn_file = WFN_pseudobands.h5
centroids_file = centroids_frac_848.txt
kin_ion_file = kin_ion.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5

# ISDF
restart = false
use_chunked_isdf = true
memory_per_device_gb = 28.0

# q->0 head: skip dipole (broken on pseudobands WFN); use BGW epshead.
wcoul0_source = epshead

# GN-PPM dynamic sigma
use_ppm_sigma = true
do_screened = true
ppm_omega_p = 2.0

# Σ(ω) grid: ±5 eV around E_F.  Protected-cond bands extend to ~6 eV above
# E_F and pseudobands start at ~6.3 eV → all pseudobands land out-of-grid.
sigma_omega_min_ev = -5.0
sigma_omega_max_ev = 5.0
sigma_omega_step_ev = 0.25

# Activate the scissor extrapolation for out-of-grid bands.
sigma_at_dft_extrapolate = true
sigma_at_dft_energies = true
sigma_debug_split_contrib = true
sigma_freq_debug_output = true
