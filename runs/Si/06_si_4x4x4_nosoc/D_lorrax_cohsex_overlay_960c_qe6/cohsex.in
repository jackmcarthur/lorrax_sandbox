# LORRAX COHSEX with full BGW head + body overlay.  Static χ₀ → static W,
# no PPM machinery — isolates the χ₀ / W body chain from the 2-pt HL
# fit.  Compare resulting Σ_xc against BGW COHSEX (00_bgw_cohsex/eqp0).
[cohsex]

restart = false
centroids_file = centroids_frac_960.txt

nval = 8
ncond = 52
nband = 60
sys_dim = 3
bare_coulomb_cutoff = 25.0

x_only = false
do_screened = true
bispinor = false
self_consistent = false

use_ppm_sigma = false
screening_method = minimax

# BGW overrides — same head + body as the HL overlay variant.
vhead = 3303.748102
whead_0freq = 150.338778
use_bgw_vcoul = true
bgw_vcoul_file = bgw_vcoul.dat

use_chunked_isdf = true
memory_per_device_gb = 28

sigma_at_dft_energies = true
sigma_freq_debug_output = true
sigma_debug_split_contrib = true
fermi_reference = midgap

wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
minimax_target_error = 1.0e-6
