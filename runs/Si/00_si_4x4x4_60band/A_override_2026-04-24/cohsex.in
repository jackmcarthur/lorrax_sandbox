# Sym Si 4x4x4 COHSEX with BGW-exact head override, matched to nosym A_xonly_2026-04-24 setup
# Goal: verify LORRAX sym ↔ nosym agreement after head override (checks SymMaps rotation)
[cohsex]

restart = false

centroids_file = centroids_frac_480.txt

nval = 8
ncond = 52
nband = 60
sys_dim = 3

x_only = false
do_screened = true
bispinor = false
self_consistent = false

use_ppm_sigma = false
screening_method = minimax

use_chunked_isdf = true
memory_per_device_gb = 28

sigma_at_dft_energies = true
sigma_freq_debug_output = true
sigma_debug_split_contrib = true
fermi_reference = midgap

bare_coulomb_cutoff = 25.0

# Exact BGW head overrides
vhead = 3303.7487
whead_0freq = 150.3388

wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
