# GWJAX input for Si 4x4x4 GN-PPM — ppm_invalid_mode=static_limit (three-way rerun at agent/memplanner-cleanup HEAD, 2026-07-08; static_limit implementation validation vs BGW invalid_gpp_mode 0/2/3)
# Base: 01_lorrax_gn_ppm/cohsex.in. Deliberate diffs from parent:
#   ppm_invalid_mode = zero      (THE variable under test; sibling dir uses 2ry)
#   ncond = 8                    (sigma window bands 1-16 = BGW band_index 1..16;
#                                 band sums still over all nband=60)
#   sigma_omega_min_ev = -13.0   (deep valence bands 1-2 sit at Edft-Ef = -12.33 eV;
#                                 the parent's -10 eV grid gave NaN sig_c(Edft) there)
#   sigma_regularization_ev = 0.35  (keeps the crossing-window minimax fit A_core =
#                                 2(|w|max/Ry + 1.5*xi)/xi <= ~78 on both omega halves —
#                                 the exact Remez solver is fast at A~83 (parent) but
#                                 pathologically slow at A~124 (first attempt, -15 eV grid,
#                                 killed after 7 min in the omega<E_F val core fit))
[cohsex]

restart = false

centroids_file = centroids_frac_480.txt

nval = 8
ncond = 8
nband = 60
sys_dim = 3

x_only = false
do_screened = true
bispinor = false
self_consistent = false

use_ppm_sigma = true
screening_method = minimax
ppm_omega_p = 2.0
ppm_fallback_omega = 2.0
ppm_invalid_mode = static_limit
sigma_omega_min_ev = -13.0
sigma_omega_max_ev = 10.0
sigma_omega_step_ev = 0.5
sigma_regularization_ev = 0.35
ppm_sigma_scale = 1.0
ppm_sigma_flip_neg = false

use_chunked_isdf = true
memory_per_device_gb = 28

sigma_at_dft_energies = true
sigma_freq_debug_output = true
sigma_debug_split_contrib = true
fermi_reference = midgap
sigma_at_dft_extrapolate = false
ppm_sigma_debug_static_norm = false
sigma_debug_quadrature = false

wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
