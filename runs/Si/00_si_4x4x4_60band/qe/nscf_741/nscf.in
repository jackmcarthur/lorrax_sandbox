&control
   prefix = 'silicon'
   pseudo_dir = './'
   calculation = 'nscf'
/
&system
   ecutwfc = 25.0
   ibrav = 0
   nat = 2
   ntyp = 1
   noncolin = .true.
   lspinorb = .true.
   no_t_rev = .true.
   nbnd = 62
/
&electrons
   electron_maxstep = 200
   conv_thr = 1.0d-10
   mixing_mode = 'plain'
   mixing_beta = 0.7
   mixing_ndim = 8
   diagonalization = 'david'
   diago_david_ndim = 4
   diago_full_acc = .true.
/

ATOMIC_SPECIES
   Si 28.085 'Si.upf'

CELL_PARAMETERS angstrom
   2.715 2.715 0.000
   0.000 2.715 2.715
   2.715 0.000 2.715

ATOMIC_POSITIONS crystal
   Si -0.125 -0.125 -0.125
   Si  0.125  0.125  0.125

K_POINTS crystal
    8
  0.000000000  0.000000000  0.000000000   1.0
  0.000000000  0.000000000  0.250000000   8.0
  0.000000000  0.000000000  0.500000000   4.0
  0.000000000  0.250000000  0.250000000   6.0
  0.000000000  0.250000000  0.500000000  24.0
  0.000000000  0.250000000  0.750000000  12.0
  0.000000000  0.500000000  0.500000000   3.0
  0.250000000  0.500000000  0.750000000   6.0
