# Si 4x4x4 COHSEX with orbit-aware ISDF centroids.
# nval=8 (all val), ncond=44 (clean gap >5 meV at band 52), nband=52.
[cohsex]

restart = false

centroids_file = centroids_frac_456.txt

nval = 8
ncond = 44
nband = 52
sys_dim = 3

x_only = false
do_screened = true
bispinor = false
self_consistent = false

use_ppm_sigma = false
screening_method = minimax

use_chunked_isdf = true
memory_per_device_gb = 28

sigma_at_dft_energies = true
sigma_freq_debug_output = false
sigma_debug_split_contrib = false
fermi_reference = midgap

wfn_file = WFN.h5
output_file = eqp0.dat
