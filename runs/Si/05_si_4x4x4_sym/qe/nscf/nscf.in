&control
   prefix = 'silicon'
   pseudo_dir = './'
   calculation = 'nscf'
/
&system
   ecutwfc = 25.0
   ibrav = 0
   nat = 2
   ntyp = 1
   noncolin = .true.
   lspinorb = .true.
   no_t_rev = .true.
   nbnd = 82
/
&electrons
   conv_thr = 1e-10
   diagonalization = 'david'
   diago_full_acc = .true.
/

ATOMIC_SPECIES
   Si 28.0855 'Si.upf'

CELL_PARAMETERS angstrom
   0.000000   2.715000   2.715000
   2.715000   0.000000   2.715000
   2.715000   2.715000   0.000000

ATOMIC_POSITIONS crystal
   Si  0.000000  0.000000  0.000000
   Si  0.250000  0.250000  0.250000

K_POINTS automatic
  4 4 4 0 0 0
