&control
   prefix = 'silicon'
   pseudo_dir = './'
   calculation = 'scf'
   disk_io = 'low'
/
&system
   ecutwfc = 25.0
   ibrav = 0
   nat = 2
   ntyp = 1
   noncolin = .true.
   lspinorb = .true.
   no_t_rev = .true.
   force_symmorphic = .true.
   nbnd = 16
/
&electrons
   electron_maxstep = 200
   conv_thr = 1.0d-10
   mixing_mode = 'plain'
   mixing_beta = 0.7
   mixing_ndim = 8
   diagonalization = 'david'
   diago_david_ndim = 4
   diago_full_acc = .true.
/

ATOMIC_SPECIES
   Si 28.085 'Si.upf'

CELL_PARAMETERS angstrom
   2.715 2.715 0.000
   0.000 2.715 2.715
   2.715 0.000 2.715

ATOMIC_POSITIONS crystal
   Si -0.125 -0.125 -0.125
   Si  0.125  0.125  0.125

K_POINTS automatic
 4 4 4 0 0 0
