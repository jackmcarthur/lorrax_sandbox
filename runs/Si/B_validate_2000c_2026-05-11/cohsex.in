# LORRAX Si 4x4x4 nosym matched COHSEX, N_mu=2000 — variant of
# runs/Si/02_si_4x4x4_nosym/D_lorrax_cohsex_overlay_1440c_noavg_v2 (which
# achieves 0.12 meV MAE at N_mu=1440). Probes whether 2000 centroids is
# also converged.
[cohsex]
restart = false
centroids_file = centroids_frac_2000.txt

nval = 8
ncond = 52
nband = 60
sys_dim = 3

x_only = false
do_screened = true
bispinor = false
self_consistent = false

use_ppm_sigma = false
screening_method = minimax

use_chunked_isdf = true
memory_per_device_gb = 28

sigma_at_dft_energies = true
sigma_freq_debug_output = true
sigma_debug_split_contrib = true
fermi_reference = midgap

wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5

bare_coulomb_cutoff = 25.0
vhead = 3303.748102
whead_0freq = 150.338778
use_bgw_vcoul = true
bgw_vcoul_file = bgw_vcoul.dat
