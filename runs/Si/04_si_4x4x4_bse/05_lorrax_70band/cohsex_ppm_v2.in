# LORRAX PPM, 70-band WFN, nband=68 (clean cutoff)
# Freq sweep: -10..+10 eV, step 0.25, regularization 0.25
[cohsex]

restart = false
centroids_file = centroids_frac_356.txt

nval = 8
ncond = 60
nband = 68
sys_dim = 3

x_only = false
do_screened = true
bispinor = false
self_consistent = false

use_ppm_sigma = true
screening_method = minimax

sigma_omega_min_ev = -10.0
sigma_omega_max_ev = 10.0
sigma_omega_step_ev = 0.5
sigma_regularization_ev = 0.25

use_chunked_isdf = true
memory_per_device_gb = 28
use_ffi_io = false
isdf_memory_mode = high_mem

bare_coulomb_cutoff = 25.0

sigma_at_dft_energies = true
sigma_freq_debug_output = true
sigma_debug_split_contrib = true
fermi_reference = midgap


wfn_file = WFN.h5
output_file = eqp0_ppm_v2.dat
sigma_omega_h5_file = sigma_mnk_ppm_v2.h5
