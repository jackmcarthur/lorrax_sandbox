# BGW absorption input for Si 4x4x4 BSE
# 8 valence + 8 conduction spinor bands
# Same coarse and fine grid (skip interpolation)

number_val_bands_coarse 8
number_cond_bands_coarse 8
number_val_bands_fine 8
number_cond_bands_fine 8

use_wfn_hdf5
use_symmetries_coarse_grid
use_symmetries_fine_grid
use_symmetries_shifted_grid
spinor

# Momentum operator: no WFNq_fi needed
use_momentum
polarization 1.0 0.0 0.0

# Full diagonalization to get eigenvalues
diagonalization
dont_use_elpa

# Coarse grid == fine grid
skip_interpolation

# Use GW quasiparticle corrections (eqp_corrections with skip_interpolation)
eqp_corrections

# Write all eigenvalues and a few eigenvectors
number_eigenvalues 500
write_eigenvectors 500

energy_resolution 0.20

degeneracy_check_override
