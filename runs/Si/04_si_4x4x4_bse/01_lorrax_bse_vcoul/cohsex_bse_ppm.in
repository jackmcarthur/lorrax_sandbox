# GWJAX input for Si 4x4x4 — PPM sigma, scalar head override from BGW debug prints
# Freq sweep: -10..+10 eV, step 0.25 eV, regularization 0.25 eV
# Head values same as cohsex_bse_headovr.in (BGW PPM vcoul0/wcoul0)
[cohsex]

restart = false

centroids_file = centroids_frac_480.txt

nval = 8
ncond = 52
nband = 60
sys_dim = 3

x_only = false
do_screened = true
bispinor = false
self_consistent = false

use_ppm_sigma = true
screening_method = minimax

sigma_omega_min_ev = -10.0
sigma_omega_max_ev = 10.0
sigma_omega_step_ev = 0.25
sigma_regularization_ev = 0.25

use_chunked_isdf = true
memory_per_device_gb = 28
use_ffi_io = true
isdf_memory_mode = low_mem

bare_coulomb_cutoff = 25.0

sigma_at_dft_energies = true
sigma_freq_debug_output = true
sigma_debug_split_contrib = true
fermi_reference = midgap

# Scalar BGW head override (from 02_bgw_sigma_debug/sigma.out, same as cohsex_bse_headovr.in)
vhead = 3303.748102330754
whead_0freq = 150.3387779808216

wfn_file = WFN.h5
output_file = eqp0_ppm_headovr.dat
sigma_omega_h5_file = sigma_mnk_ppm.h5
