# GWJAX input for Si 4x4x4 COHSEX + BSE — using BGW's MC-averaged vcoul
# Parent: ../00_lorrax_bse/cohsex.in + use_bgw_vcoul
[cohsex]

restart = false

centroids_file = centroids_frac_480.txt

nval = 8
ncond = 52
nband = 60
sys_dim = 3

x_only = true
do_screened = false
bispinor = false
self_consistent = false

use_ppm_sigma = false
screening_method = minimax

use_chunked_isdf = true
memory_per_device_gb = 28
use_ffi_io = true
isdf_memory_mode = low_mem

# Match BGW screened_coulomb_cutoff (= ecutwfc for this system)
bare_coulomb_cutoff = 25.0

sigma_at_dft_energies = true
sigma_freq_debug_output = true
sigma_debug_split_contrib = true
fermi_reference = midgap

# Read BGW's MC-averaged v(q+G) from epsilon write_vcoul output
use_bgw_vcoul = false
bgw_vcoul_file = /pscratch/sd/j/jackm/lorrax_sandbox/runs/Si/04_si_4x4x4_bse/01_bgw_eps_vcoul/vcoul

wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
