# BGW Haydock absorption — 8 val × 8 cond, 100 iterations
# To match LORRAX Lanczos truncated to similar Krylov depth.

number_val_bands_coarse 8
number_cond_bands_coarse 8
number_val_bands_fine 8
number_cond_bands_fine 8

use_wfn_hdf5
use_symmetries_coarse_grid
use_symmetries_fine_grid
use_symmetries_shifted_grid
spinor

use_momentum
polarization 1.0 0.0 0.0

# Haydock continued-fraction with 100 iterations
haydock
number_iterations 50

skip_interpolation
eqp_corrections

energy_resolution 0.15

degeneracy_check_override
