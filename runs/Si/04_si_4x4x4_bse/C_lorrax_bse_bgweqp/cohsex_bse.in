# BSE on Si 4x4x4 — input only used for restart-bundle path lookup.
# QP corrections come from BGW eqp1.dat at run time via --eqp.
[cohsex]

restart = true
centroids_file = centroids_frac_480.txt

nval = 8
ncond = 52
nband = 60
sys_dim = 3

x_only = false
do_screened = true
bispinor = false
self_consistent = false

use_ppm_sigma = false
screening_method = minimax

use_chunked_isdf = true
memory_per_device_gb = 28
use_ffi_io = true
isdf_memory_mode = low_mem

bare_coulomb_cutoff = 25.0

sigma_at_dft_energies = true

use_bgw_vcoul = true
bgw_vcoul_file = /pscratch/sd/j/jackm/lorrax_sandbox/runs/Si/04_si_4x4x4_bse/01_bgw_eps_vcoul/vcoul

# q=0 head: cohsex.in overrides removed — values come from the restart
# bundle (vhead/whead datasets persisted by gw_jax post-solve_w).
# Re-add `vhead = ...` / `whead_0freq = ...` here to override the restart.
wfn_file = WFN.h5
output_file = eqp0_unused.dat
sigma_omega_h5_file = sigma_mnk.h5
