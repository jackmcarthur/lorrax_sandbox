&control
   prefix = 'VI3'
   pseudo_dir = './'
   calculation = 'scf'
   verbosity = 'high'
   disk_io = 'low'
/
&system
   ecutwfc = 80.0
   ibrav = 0
   nat = 8
   ntyp = 2
   noncolin = .true.
   lspinorb = .true.
   no_t_rev = .true.
   nosym = .true.            ! keep full BZ; do NOT symmetrize the seeded orbital order
   nbnd = 90
   assume_isolated = '2D'
   occupations = 'fixed'
   constrained_magnetization = 'none'
   starting_magnetization(1) = 2.0   ! V3+ d2 FM seed, +z easy axis
   starting_magnetization(2) = 0.0
   angle1(1) = 0.0
   angle2(1) = 0.0
   ! --- The fix: seed the V-3d occupation matrix to the d2 insulating state ---
   ! (root cause was the metallic/orbital-bistable SCF attractor, NOT U magnitude)
   Hubbard_occ(1,1) = 2.0   ! V3+ d2 reference occupation (PP default = neutral d3)
   starting_ns_eigenvalue(1,1,1) = 0.0
   starting_ns_eigenvalue(2,1,1) = 0.0
   starting_ns_eigenvalue(3,1,1) = 0.0
   starting_ns_eigenvalue(4,1,1) = 1.0
   starting_ns_eigenvalue(5,1,1) = 1.0
   starting_ns_eigenvalue(1,2,1) = 0.0
   starting_ns_eigenvalue(2,2,1) = 0.0
   starting_ns_eigenvalue(3,2,1) = 0.0
   starting_ns_eigenvalue(4,2,1) = 0.0
   starting_ns_eigenvalue(5,2,1) = 0.0
/
&electrons
   startingwfc = 'atomic+random'
   electron_maxstep = 300
   conv_thr = 1e-6          ! plenty to resolve a ~0.5 eV gap
   mixing_mode = 'plain'    ! with ns PINNED there is no +U feedback; plain converges VI3 charge fine
   mixing_beta = 0.3
   mixing_ndim = 8
   mixing_fixed_ns = 250    ! PIN the seeded d2 occupation matrix the whole run (both mixers sloshed on release)
   diagonalization = 'david'
   diago_full_acc = .true.
/

ATOMIC_SPECIES
   V   50.942 'V.upf'
   I  126.904 'I.upf'

CELL_PARAMETERS angstrom
   6.840000   0.000000   0.000000
  -3.420000   5.923607   0.000000
   0.000000   0.000000  18.000000

ATOMIC_POSITIONS crystal
   V   0.3333373259  0.6666630733  0.0004399437
   V   0.6666626741  0.3333369267  0.9995600603
   I   0.3418148668  0.9994230169  0.9062750255
   I   0.0005900624  0.3423972300  0.9062736328
   I   0.6575994572  0.6581845973  0.9062776988
   I   0.6581851332  0.0005769641  0.0937249445
   I   0.9994099166  0.6576027700  0.0937263372
   I   0.3424005428  0.3418154327  0.0937222712

K_POINTS automatic
 6 6 1 0 0 0

HUBBARD (ortho-atomic)
U V-3d 5.0
