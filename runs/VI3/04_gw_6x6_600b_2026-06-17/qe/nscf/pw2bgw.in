&input_pw2bgw
   prefix = 'VI3'
   real_or_complex = 2
   wfng_flag = .true.
   wfng_file = 'WFN'
   wfng_kgrid = .true.
   wfng_nk1 = 6
   wfng_nk2 = 6
   wfng_nk3 = 1
   wfng_dk1 = 0.0
   wfng_dk2 = 0.0
   wfng_dk3 = 0.0
   vxc_flag = .true.
   vxc_diag_nmin = 1
   vxc_diag_nmax = 600
   kih_flag = .true.
/
! kih_flag=.true. + ONE MPI task is required for the DFT+U case (the orthoUwfc/
! .hub1 Hubbard-projector write path) -- per user. Run with MPICH_GPU_SUPPORT_ENABLED=0.
