&control
   prefix = 'VI3'
   pseudo_dir = './'
   calculation = 'nscf'
   verbosity = 'high'
   wf_collect = .true.
   disk_io = 'low'
/
&system
   ecutwfc = 80.0
   ibrav = 0
   nat = 8
   ntyp = 2
   noncolin = .true.
   lspinorb = .true.
   no_t_rev = .true.
   nosym = .true.            ! full BZ (36 k-pts); avoids LORRAX IBZ-unfold + preserves orbital order
   nbnd = 600
   assume_isolated = '2D'
   ! DFT+U gapped state: ns read from the run-03 SCF .save; U/Hubbard_occ must match.
   starting_magnetization(1) = 2.0
   starting_magnetization(2) = 0.0
   angle1(1) = 0.0
   angle2(1) = 0.0
   Hubbard_occ(1,1) = 2.0
/
&electrons
   electron_maxstep = 200
   conv_thr = 1e-6
   diagonalization = 'david'
   diago_david_ndim = 4
   diago_full_acc = .true.
/

ATOMIC_SPECIES
   V   50.942 'V.upf'
   I  126.904 'I.upf'

CELL_PARAMETERS angstrom
   6.840000   0.000000   0.000000
  -3.420000   5.923607   0.000000
   0.000000   0.000000  18.000000

ATOMIC_POSITIONS crystal
   V   0.3333373259  0.6666630733  0.0004399437
   V   0.6666626741  0.3333369267  0.9995600603
   I   0.3418148668  0.9994230169  0.9062750255
   I   0.0005900624  0.3423972300  0.9062736328
   I   0.6575994572  0.6581845973  0.9062776988
   I   0.6581851332  0.0005769641  0.0937249445
   I   0.9994099166  0.6576027700  0.0937263372
   I   0.3424005428  0.3418154327  0.0937222712

K_POINTS automatic
 6 6 1 0 0 0

HUBBARD ortho-atomic
U V-3d 5.0
