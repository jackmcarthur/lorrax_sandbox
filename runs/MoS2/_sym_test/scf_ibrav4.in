&control
   prefix = 'MoS2'
   pseudo_dir = './'
   calculation = 'scf'
/
&system
   ecutwfc = 30.0
   ibrav = 4
   celldm(1) = 5.978773
   celldm(3) = 3.792302
   nat = 3
   ntyp = 2
   noncolin = .true.
   lspinorb = .true.
   no_t_rev = .true.
   nbnd = 34
   assume_isolated = '2D'
/
&electrons
   electron_maxstep = 1
   conv_thr = 1e-6
   diagonalization = 'david'
/

ATOMIC_SPECIES
   Mo 95.94 'Mo.upf'
   S  32.07 'S.upf'

ATOMIC_POSITIONS crystal
   Mo  0.666667  0.333333  0.000000
   S   0.333333  0.666667  0.131928
   S   0.333333  0.666667 -0.131928

K_POINTS automatic
 3 3 1 0 0 0
