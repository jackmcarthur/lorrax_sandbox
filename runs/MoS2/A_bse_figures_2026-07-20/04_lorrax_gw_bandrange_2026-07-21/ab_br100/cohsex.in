[cohsex]
# GN-PPM (Godby-Needs plasmon-pole) G0W0 producer for the MoS2 BSE-figures run.
# 6x6 coarse grid (WFN from ../qe/nscf, 210 bands).  This run BOTH:
#   (1) writes the QP corrections (eqp0/eqp1) for the GW bandstructure figure, and
#   (2) builds the BSE restart (tmp/isdf_tensors_*.h5, tmp/zeta_q.h5, V_qmunu,
#       W0_qmunu, psi_full_y) that bse.exciton_bands consumes for the 12x12
#       exciton bandstructure via the bse_k_grid coarse->fine economy route.
#
# Owner spec: GN-PPM, ~200 bands total, 1600 centroids, sigma bandrange
# (QP corrections) up to 100 bands.  Band-window mapping (common/meta.py):
#   nval=26  -> sigma valence edge  b_id_1 = nelec-nval = 0
#   ncond=74 -> sigma cond edge     b_id_3 = nelec+ncond = 100  (QP for bands 1..100)
#   nband=200-> sum-over-states (screening + CH)  b_id_4_user = 200
compute_mode = gn_ppm
restart = false
centroids_file = centroids.txt
nval = 26
ncond = 74
nband = 200
sys_dim = 2
x_only = false
do_screened = true
bispinor = false
self_consistent = false
use_ppm_sigma = true
screening_method = minimax
ppm_omega_p = 2.0
ppm_fallback_omega = 2.0
sigma_omega_min_ev = -10.0
sigma_omega_max_ev = 10.0
sigma_omega_step_ev = 0.5
sigma_regularization_ev = 0.25
use_chunked_isdf = true
memory_per_device_gb = 28
sigma_at_dft_energies = true
sigma_freq_debug_output = true
sigma_debug_split_contrib = true
fermi_reference = midgap
wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
bare_coulomb_cutoff = 30.0
