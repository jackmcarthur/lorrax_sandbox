# LORRAX input TEMPLATE for MoS2 COHSEX — flags set to match BGW.
# /pscratch/sd/j/jackm/lorrax_sandbox/runs/MoS2/B_validate_examples_2026-05-11 is expanded by ./run.sh before invoking gw.gw_jax;
# do NOT pass this .tmpl file directly to gw.gw_jax.
#
# Diff vs lorrax_ref/cohsex_default/cohsex.in (see docs/BGW_LORRAX_MATCHING.md):
#   bare_coulomb_cutoff = 30.0  — convention 1: match BGW screened_coulomb_cutoff.
#                                 (LORRAX default is 4·ecutwfc.)
#   use_bgw_vcoul       = true  — convention 5: consume BGW's MC-averaged v(q+G).
#   bgw_vcoul_file      = ...   — requires bgw_ref/cohsex_matched/ to have run
#                                 with `write_vcoul` in epsilon.inp.
#   wcoul0_source       = epshead — convention 6: q→0 head from BGW eps0mat.h5.
[cohsex]
restart = false
centroids_file = centroids_frac_640.txt
nval = 26
ncond = 54
nband = 80
sys_dim = 2
x_only = false
do_screened = true
bispinor = false
self_consistent = false

use_ppm_sigma = false
screening_method = minimax
sigma_at_dft_energies = true
sigma_debug_split_contrib = true
fermi_reference = midgap

use_chunked_isdf = true
memory_per_device_gb = 28

# Matching overrides:
bare_coulomb_cutoff = 30.0
use_bgw_vcoul = true
bgw_vcoul_file = /pscratch/sd/j/jackm/lorrax_sandbox/runs/MoS2/B_validate_examples_2026-05-11/bgw_cohsex_matched/vcoul
wcoul0_source = epshead

wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5

K_POINTS {crystal_b}
4
  0.0000 0.0000 0.0000 80
  0.0000 0.5000 0.0000 80
  0.3333 0.3333 0.0000 80
  0.0000 0.0000 0.0000 80
