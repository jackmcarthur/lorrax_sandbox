# LORRAX input for MoS2 COHSEX — library defaults, no BGW-matching overrides.
# See docs/BGW_LORRAX_MATCHING.md for the matched-vs-default contract.
[cohsex]
restart = false
centroids_file = centroids_frac_640.txt
nval = 26
ncond = 54
nband = 80
sys_dim = 2
x_only = false
do_screened = true
bispinor = false
self_consistent = false

use_ppm_sigma = false
screening_method = minimax
sigma_at_dft_energies = true
sigma_debug_split_contrib = true
fermi_reference = midgap

use_chunked_isdf = true
memory_per_device_gb = 28

wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5

K_POINTS {crystal_b}
4
  0.0000 0.0000 0.0000 80
  0.0000 0.5000 0.0000 80
  0.3333 0.3333 0.0000 80
  0.0000 0.0000 0.0000 80
