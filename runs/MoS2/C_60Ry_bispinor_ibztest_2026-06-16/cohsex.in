[cohsex]
wfn_file = WFN.h5
nval = 4
ncond = 4
nband = 32
sys_dim = 2
bispinor = true

centroids_file = centroids_frac_640.txt
centroids_file_current = centroids_frac_668_current.txt

# Single user-facing memory knob.  No r_chunk_size / band_chunk_size
# overrides — the chunker auto-sizes from this budget.
memory_per_device_gb = 30.0

restart = false
max_r_chunks = -1

# Milestone A: screened-charge COHSEX (Σ_SX + Σ_COH on charge W⁰⁰) + bare
# Breit Σ^B.  This is the χ_μν = χ⁰⁰-only reduction — the existing scalar
# solve_w gives W⁰⁰, the bare V^{ij} tiles flow straight into Σ^B.
x_only = false
do_screened = true
screening = cohsex

# Head bypass (mirrors parent D_60Ry_bispinor smoke config): supply explicit
# overrides so do_screened does not require dipole.h5 / eps0mat.h5.  Both
# heads set to 0 — the head cancels in the bispinor-vs-scalar charge-block
# comparison, and is irrelevant to the machinery validation.  Refine later.
vhead = 0.0
whead_0freq = 0.0
