[cohsex]
wfn_file = WFN.h5
nval = 4
ncond = 4
nband = 32
sys_dim = 2
bispinor = false

centroids_file = centroids_frac_640.txt

# Single user-facing memory knob.
memory_per_device_gb = 30.0

restart = false
max_r_chunks = -1

# Scalar reference for the charge-block comparison: same screened-charge
# COHSEX (Σ_SX + Σ_COH on W⁰⁰) as the bispinor run, but bispinor=false so
# there is NO Σ^B.  The bispinor run's Σ_SX/Σ_COH (charge channel) must
# match these.
x_only = false
do_screened = true
screening = cohsex

vhead = 0.0
whead_0freq = 0.0
