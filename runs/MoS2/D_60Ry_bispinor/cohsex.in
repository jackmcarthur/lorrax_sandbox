[cohsex]
wfn_file = WFN.h5
nval = 4
ncond = 4
nband = 32
sys_dim = 2
bispinor = true

centroids_file = centroids_frac_640.txt
centroids_file_current = centroids_frac_668_current.txt

# Single user-facing memory knob.  No r_chunk_size / band_chunk_size
# overrides — the chunker auto-sizes from this budget.
memory_per_device_gb = 30.0

restart = false
max_r_chunks = -1

x_only = true
do_screened = false
screening = cohsex

# x_only smoke test: bypass dipole.h5 / eps0mat.h5 head computation by
# supplying explicit overrides.  Head terms are irrelevant for bare-X in
# the bispinor charge-channel forwarding stub (see gw_init.compute_V_q
# bispinor branch).  Set both to 0 so the Σ-head contribution is zero;
# the bare-X kernel itself does not consume vhead.
vhead = 0.0
whead_0freq = 0.0
