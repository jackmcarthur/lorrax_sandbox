&control
   prefix = 'MoS2'
   pseudo_dir = './'
   calculation = 'nscf'
/
&system
   ecutwfc = 30.0
   ibrav = 0
   nat = 3
   ntyp = 2
   noncolin = .true.
   lspinorb = .true.
   no_t_rev = .true.
   nbnd = 82
