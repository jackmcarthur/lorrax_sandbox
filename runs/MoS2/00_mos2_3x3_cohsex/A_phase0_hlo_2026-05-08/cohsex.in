# Phase 0a — HLO dump of the bispinor smoke bed at n_rmu_C=640, n_rmu_T=656.
# Identical to A_bispinor_smoke_2026-05-08/cohsex.in.  Re-runs ζ-fit (4
# channels) + V_q (7 unique tiles) from scratch so XLA dumps every jit.
[cohsex]

restart = false

centroids_file = centroids_frac_640.txt
centroids_file_current = centroids_frac_656_current.txt

nval = 26
ncond = 54
nband = 80
sys_dim = 2

x_only = true
do_screened = false
bispinor = true
self_consistent = false

use_ppm_sigma = false
screening_method = minimax
sigma_debug_split_contrib = true
fermi_reference = midgap
sigma_at_dft_extrapolate = false
sigma_at_dft_energies = true

memory_per_device_gb = 28.0
