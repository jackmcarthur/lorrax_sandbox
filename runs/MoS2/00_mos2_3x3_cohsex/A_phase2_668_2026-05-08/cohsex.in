# Phase 2 — first end-to-end test of n_rmu_T = 668 (4·167, NOT 16·k).
# After v_q_tile.py + v_q_bispinor.py patch: compute_V_q_tile pads
# n_rmu internally to mesh-product (16); writes use valid_shape=668 so
# on-disk extent stays logical.  ζ-fit at 668 needs no changes
# (single-axis sharding, 668 % 4 == 0).
[cohsex]

restart = false

centroids_file = centroids_frac_640.txt
centroids_file_current = centroids_frac_668_current.txt

nval = 26
ncond = 54
nband = 80
sys_dim = 2

x_only = true
do_screened = false
bispinor = true
self_consistent = false

use_ppm_sigma = false
screening_method = minimax
sigma_debug_split_contrib = true
fermi_reference = midgap
sigma_at_dft_extrapolate = false
sigma_at_dft_energies = true

memory_per_device_gb = 28.0
