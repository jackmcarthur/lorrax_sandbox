# LORRAX input for MoS2 3x3 COHSEX, FULL fair-comparison overlay vs BGW.
# - bare_coulomb_cutoff = 30.0 (= BGW screened_coulomb_cutoff = ecutwfc)
# - use_bgw_vcoul       = true  (BGW MC-averaged v(q+G) for body, see compare.SKILL 4j)
# - wcoul0_source       = epshead (use BGW eps0mat.h5 epshead for the q→0 head)
# Variant of 00_lorrax_cohsex.
[cohsex]
restart = false
centroids_file = centroids_frac_640.txt
nval = 26
ncond = 54
nband = 80
sys_dim = 2
x_only = false
do_screened = true
bispinor = false
self_consistent = false
use_ppm_sigma = false
screening_method = minimax
sigma_debug_split_contrib = true
fermi_reference = midgap
sigma_at_dft_extrapolate = false
sigma_at_dft_energies = true
use_chunked_isdf = true
memory_per_device_gb = 28
write_no_head_vw = false
debug_hartree = false
write_w_copies_debug = false
wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
sigma_freq_debug_output = true
bare_coulomb_cutoff = 30.0

# BGW body overlay (re-using D_bgw_hl_ppm vcoul; same screened_coulomb_cutoff
# 30 Ry, same q-grid, same cell_slab_truncation, same 4-kpoint sigma block).
use_bgw_vcoul = true
bgw_vcoul_file = /pscratch/sd/j/jackm/lorrax_sandbox/runs/MoS2/00_mos2_3x3_cohsex/D_bgw_hl_ppm/vcoul

# Head from BGW eps0mat.h5 (epshead) — gives the BGW-convention W(q→0,G=0).
wcoul0_source = epshead

K_POINTS {crystal_b}
4
  0.0000 0.0000 0.0000 80
  0.0000 0.5000 0.0000 80
  0.3333 0.3333 0.0000 80
  0.0000 0.0000 0.0000 80
