# LORRAX input for MoS2 12x12 COHSEX + do_screened — 1000-CENTROID variant of
# ../00_lorrax_cohsex/cohsex.in (owner question: does a more converged ISDF
# basis smooth the exciton bands?).  ONLY centroids_file differs; all physics
# keys verbatim.  centroids_frac_1000.txt generated in this dir by
# centroid.kmeans_cli (seed 42, --no-orbit literal points — the orbit-closure
# failure keeps zeta storage FULL-BZ, which bse.vq_interp requires; see
# run_kmeans.log).  Purpose: 144-q full-BZ restart (V_qmunu, W0_qmunu,
# psi_full_y, zeta_q.h5) to train bse.vq_interp at 1000 mu.
[cohsex]
restart = false
centroids_file = centroids_frac_1000.txt
nval = 26
ncond = 54
nband = 80
sys_dim = 2
x_only = false
do_screened = true
bispinor = false
self_consistent = false
use_ppm_sigma = false
screening_method = minimax
sigma_debug_split_contrib = true
fermi_reference = midgap
sigma_at_dft_extrapolate = false
sigma_at_dft_energies = true
use_chunked_isdf = true
memory_per_device_gb = 28
write_no_head_vw = false
debug_hartree = false
write_w_copies_debug = false
wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
sigma_freq_debug_output = true
bare_coulomb_cutoff = 30.0

K_POINTS {crystal_b}
4
  0.0000 0.0000 0.0000 80
  0.0000 0.5000 0.0000 80
  0.3333 0.3333 0.0000 80
  0.0000 0.0000 0.0000 80
