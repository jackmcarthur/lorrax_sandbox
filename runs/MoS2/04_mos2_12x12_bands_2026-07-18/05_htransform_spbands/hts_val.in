# htransform SINGLE-PARTICLE bands input — VALENCE window (abs bands 20-28).
# Companion of hts_cond.in (see its header for the nb <= 8 capacity math and
# the nband=absolute-top trap).  Window design constraints (gap_scan.py on
# the stored restart energies):
#   (1) boundaries must NOT cut a Kramers pair (pairs (20,21),(22,23),...
#       are EXACTLY degenerate at 12x12) and should sit at healthy min-gaps:
#       here 19|20 = 64.7 meV, 27|28 = 75.8 meV;
#   (2) plotted bands must be deep below the window top (f-transform
#       conditioning f' >= ~0.8 for bands 22-25 at default a = 4*BW(27):
#       |eps_25.max - shift| = 2.61 eV vs a = 3.63 eV).
# Plot takes valence 22-25 (idx 2-5); 26,27 are the compression-sacrifice
# guard pair.  v2 of this file used (22,30), whose 29|30 top boundary has a
# 37.6 meV min-gap -> ringing contaminated even deep bands (515 meV).
[cohsex]
restart = false
centroids_file = centroids_frac_640.txt
nval = 6
ncond = 2
nband = 28
sys_dim = 2
x_only = false
do_screened = true
bispinor = false
self_consistent = false
use_ppm_sigma = false
screening_method = minimax
sigma_debug_split_contrib = true
fermi_reference = midgap
sigma_at_dft_extrapolate = false
sigma_at_dft_energies = true
use_chunked_isdf = true
memory_per_device_gb = 28
write_no_head_vw = false
debug_hartree = false
write_w_copies_debug = false
wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
sigma_freq_debug_output = true
bare_coulomb_cutoff = 30.0

K_POINTS {crystal_b}
4
  0.0000 0.0000 0.0000 1   # Gamma
  0.0000 0.5000 0.0000 15  # M
  0.3333 0.3333 0.0000 8   # K
  0.0000 0.0000 0.0000 16  # Gamma
