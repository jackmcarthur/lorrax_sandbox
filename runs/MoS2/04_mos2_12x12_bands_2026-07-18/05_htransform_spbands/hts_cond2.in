# htransform SINGLE-PARTICLE bands input — CONDUCTION-PLOT window (26-34).
# Companion of hts_cond.in (see its header for the nb <= 8 capacity math and
# the nband=absolute-top trap).  Window design (gap_scan.py):
#   both boundaries sit at the two LARGEST adjacent-band gaps in the whole
#   spectrum — 25|26 = 1700 meV (the fundamental gap) and 33|34 = 2194 meV —
#   so no Kramers pair is cut and fH is maximally k-smooth.  nval=0 is
#   intentional (window = (nelec, nelec+8) = all-conduction).
# Plotted bands 26-31 (idx 0-5); 32,33 are the compression-sacrifice guard
# pair.  The driver script passes a_band_index=2 (band 28, the flattest
# window band, BW 0.72 eV -> a = 2.87 eV) so the plotted-top pair 30,31
# keeps f' ~ 0.31 (default a = 4*BW(33) = 8.1 eV would give f' ~ 0.05).
# v1 of this file used (25,33), whose bottom boundary 24|25 CUTS the
# (24,25) Kramers pair (0.000 meV) -> catastrophic off-grid failure
# (1.5 eV on band 26) — same mechanism as the sibling's w2331 A/B and the
# Si degeneracy root-cause (window truncation of degenerate multiplets).
[cohsex]
restart = false
centroids_file = centroids_frac_640.txt
nval = 0
ncond = 8
nband = 34
sys_dim = 2
x_only = false
do_screened = true
bispinor = false
self_consistent = false
use_ppm_sigma = false
screening_method = minimax
sigma_debug_split_contrib = true
fermi_reference = midgap
sigma_at_dft_extrapolate = false
sigma_at_dft_energies = true
use_chunked_isdf = true
memory_per_device_gb = 28
write_no_head_vw = false
debug_hartree = false
write_w_copies_debug = false
wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
sigma_freq_debug_output = true
bare_coulomb_cutoff = 30.0

K_POINTS {crystal_b}
4
  0.0000 0.0000 0.0000 1   # Gamma
  0.0000 0.5000 0.0000 15  # M
  0.3333 0.3333 0.0000 8   # K
  0.0000 0.0000 0.0000 16  # Gamma
