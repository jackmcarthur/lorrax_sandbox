# GWJAX bispinor end-to-end smoke test for MoS2 3x3
# Goal: confirm that
#   (a) ζ_q_mu1/2/3.h5 are written and non-zero,
#   (b) v_q_bispinor.h5 has all 7 unique tiles non-zero,
#   (c) total wall is in the same ballpark as 4× scalar ζ-fit + ~1× V_q,
#   (d) the CC tile read back is bit-identical to the scalar V_q.
[cohsex]

restart = false

centroids_file = centroids_frac_584.txt
centroids_file_current = centroids_frac_428_current.txt

nval = 26
ncond = 54
nband = 80
sys_dim = 2

x_only = true
do_screened = false
bispinor = true
self_consistent = false

use_ppm_sigma = false
screening_method = minimax
sigma_debug_split_contrib = true
fermi_reference = midgap
sigma_at_dft_extrapolate = false
sigma_at_dft_energies = true

memory_per_device_gb = 28.0
