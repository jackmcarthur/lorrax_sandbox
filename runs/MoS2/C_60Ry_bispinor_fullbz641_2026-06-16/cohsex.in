[cohsex]
wfn_file = WFN.h5
nval = 4
ncond = 4
nband = 32
sys_dim = 2
bispinor = true

# Both centroid sets ORBIT-CLOSED → full bispinor IBZ cascade activates
# (charge 641 regenerated orbit-aware 2026-06-16; transverse 668 already closed).
centroids_file = centroids_frac_641.txt
centroids_file_current = centroids_frac_668_current.txt

memory_per_device_gb = 30.0

restart = false
max_r_chunks = -1

# Milestone A screened-charge COHSEX + bare Breit, run with IBZ ACTIVE
# (NO LORRAX_FORCE_FULL_BZ) to validate the bispinor IBZ symmetry path
# against the full-BZ reference.
x_only = false
do_screened = true
screening = cohsex

vhead = 0.0
whead_0freq = 0.0
