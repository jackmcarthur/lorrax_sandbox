# LORRAX MoS2 HL-PPM with noavg overlay
[cohsex]
restart = false
centroids_file = centroids_frac_2400.txt

nval = 26
ncond = 54
nband = 80
sys_dim = 2
bare_coulomb_cutoff = 30.0

x_only = false
do_screened = true
bispinor = false
self_consistent = false

use_ppm_sigma = true
ppm_model = hl
screening_method = minimax

# HL probe Omega in Ry (above x_max ~few Ry); 200 Ry asymptotic regime
ppm_omega_p = 200.0
ppm_fallback_omega = 2.0
sigma_omega_min_ev = -10.0
sigma_omega_max_ev = 10.0
sigma_omega_step_ev = 0.5
sigma_regularization_ev = 0.25

# Head + body BGW overlay (post-cherry-pick of 0bfcca6)
vhead = 1649.143966
whead_0freq = 397.409958
use_bgw_vcoul = true
bgw_vcoul_file = bgw_vcoul.dat

use_chunked_isdf = true
memory_per_device_gb = 28
sigma_at_dft_energies = true
sigma_freq_debug_output = true
sigma_debug_split_contrib = true
fermi_reference = midgap

wfn_file = WFN.h5
output_file = eqp0.dat
sigma_omega_h5_file = sigma_mnk.h5
minimax_target_error = 1.0e-6
